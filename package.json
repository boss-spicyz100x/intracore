{
  "name": "intracore",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot server.ts",
    "start": "bun server.ts",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "seed": "bun src/db/seed.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "format": "bunx oxfmt --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@elysiajs/swagger": "^1.3.1",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.27",
    "pino": "^10.3.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/uuid": "^11.0.0",
    "drizzle-kit": "^0.31.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "lint-staged": {
    "*.ts": [
      "oxlint",
      "oxfmt --write"
    ],
    "*.{json,md,toml,yaml}": [
      "oxfmt --write"
    ]
  }
}
