{
  "name": "intracore",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "dev:serverless": "wrangler dev",
    "dev:server": "bun --hot server.ts",
    "deploy": "wrangler deploy",
    "generate": "drizzle-kit generate",
    "migrate:local": "wrangler d1 execute intracore --local --file=./migrations/0000_free_satana.sql",
    "migrate:server": "drizzle-kit migrate --config=drizzle.server.config.ts",
    "start:server": "bun server.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "format": "bunx oxfmt --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@elysiajs/swagger": "^1.3.1",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.27",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260301.1",
    "@types/bun": "latest",
    "@types/uuid": "^11.0.0",
    "drizzle-kit": "^0.31.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "wrangler": "^4.69.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "lint-staged": {
    "*.ts": [
      "oxlint",
      "oxfmt --write"
    ],
    "*.{json,md,toml,yaml}": [
      "oxfmt --write"
    ]
  }
}
